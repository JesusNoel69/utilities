<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="utilities.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:utilities" 
    xmlns:views="clr-namespace:utilities.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Utilities"
    >
    <TabBar>
        <ShellContent
            Title="Words"
            Icon="accent_image.webp"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage"/>
        <ShellContent
            Title="Picker"
            Icon="accent_image.webp"
            ContentTemplate="{DataTemplate views:ColorPickerPage}"
            Route="ColorPickerPage"/>
        <ShellContent
            Title="File"
            Icon="accent_image.webp"
            ContentTemplate="{DataTemplate views:FileManagerPage}"
            Route="FileManager"/>
    </TabBar>
</Shell>
